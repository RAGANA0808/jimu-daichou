# =========================================
# 寺務台帳 環境変数テンプレート
# このファイルをコピーして .env を作成してください
# 本ファイルには実際の値を書き込まないこと
# =========================================

# --- アプリ全体 ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3104
TZ=Asia/Tokyo

# --- データベース (PostgreSQL) ---
# Supabase を使う場合は Supabase ダッシュボードの Connection String
DATABASE_URL="postgresql://user:password@localhost:5432/jimu_daichou?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/jimu_daichou?schema=public"

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google OAuth / Calendar API ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3104/api/auth/google/callback

# --- セッション ---
# 32 文字以上のランダム文字列 (openssl rand -hex 32 等で生成)
SESSION_SECRET=

# --- 初期テナント (自寺) ---
# seed.ts で使用
INITIAL_TENANT_NAME="○○寺"
INITIAL_TENANT_SLUG="my-temple"
INITIAL_ADMIN_EMAIL=
